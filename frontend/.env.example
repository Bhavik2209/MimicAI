# Public client-side API base (optional). Keep default to use Next proxy route.
NEXT_PUBLIC_API_BASE_URL=/api/backend

# Frontend -> backend proxy target URL (required in Vercel)
BACKEND_URL=https://mimicaiai.vercel.app

# Must match backend INTERNAL_API_KEY (required)
INTERNAL_API_KEY=replace-with-strong-secret

# Neon Auth settings (required)
NEON_AUTH_BASE_URL=https://your-neon-auth-base-url
NEON_AUTH_COOKIE_SECRET=replace-with-long-random-secret
